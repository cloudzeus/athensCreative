# PostgreSQL connection for Prisma (see prisma.config.ts)
DATABASE_URL="postgres://user:password@localhost:5432/athenscreative?schema=public"

# Secret for signing admin session cookies — generate with: openssl rand -hex 32
AUTH_SECRET=""

# Optional: password used by `prisma db seed` for the admin user (defaults exist in seed.ts)
# ADMIN_SEED_PASSWORD=""

# Mailgun (HTTP API — used by src/lib/mailgun.ts). EU-region account → api.eu.mailgun.net
MAILGUN_API_KEY=""
MAILGUN_DOMAIN="athens-creative.com"
MAILGUN_BASE_URL="https://api.eu.mailgun.net"
MAIL_FROM="Athens Creative English <despina@athens-creative.com>"
MAIL_TO_ADMIN="info@athens-creative.com"
